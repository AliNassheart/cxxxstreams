# Server
PORT=4000
NODE_ENV=development
CLIENT_URL=http://localhost:5173

# JWT
JWT_ACCESS_SECRET=replace_with_a_long_random_secret
JWT_REFRESH_SECRET=replace_with_another_long_random_secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# PostgreSQL
DATABASE_URL=postgres://streamhub:streamhub@localhost:5432/streamhub
PGSSL=false

# Object storage (S3-compatible: AWS S3, Cloudflare R2, MinIO, DigitalOcean Spaces)
S3_ENDPOINT=https://s3.amazonaws.com
S3_REGION=us-east-1
S3_BUCKET=streamhub-media
S3_ACCESS_KEY_ID=replace_me
S3_SECRET_ACCESS_KEY=replace_me
S3_PUBLIC_URL=https://streamhub-media.s3.amazonaws.com

# RTMP / HLS (owner-operated ingest only)
RTMP_STREAM_KEY_SECRET=replace_with_a_long_random_secret
HLS_BASE_URL=http://localhost:8080/hls
